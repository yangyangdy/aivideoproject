APP_NAME=milvus-vector-service
APP_HOST=0.0.0.0
APP_PORT=8000

# Logging (default: file only, no console)
LOG_DIR=logs
LOG_FILE=app.log
LOG_LEVEL=INFO
LOG_CONSOLE=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=vector_db
MYSQL_TABLE=vector_data
MYSQL_ID_COLUMN=id
MYSQL_MATERIAL_ID_COLUMN=material_id
MYSQL_TENANT_ID_COLUMN=tenant_id
MYSQL_VECTOR_COLUMN=embedding
MYSQL_EMBEDDING_MODEL_COLUMN=embedding_model
MYSQL_DIMENSION_COLUMN=dimension
MYSQL_CONTENT_HASH_COLUMN=content_hash
MYSQL_UID_COLUMN=uid
MYSQL_TAG_COLUMN=tag
MYSQL_CREATE_TIME_COLUMN=create_time
MYSQL_UPDATE_TIME_COLUMN=update_time

MILVUS_URI=http://127.0.0.1:19530
MILVUS_TOKEN=
MILVUS_COLLECTION_NAME=ai_material_embedding
MILVUS_VECTOR_DIM=2048
MILVUS_METRIC_TYPE=COSINE
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_INDEX_NLIST=1024
MILVUS_SEARCH_NPROBE=16
MILVUS_SEARCH_EF=64

SYNC_BATCH_SIZE=1000
SYNC_STATE_FILE=state/sync_cursor.json

EMBEDDING_API_URL=https://operator.las.cn-beijing.volces.com/api/v1/embeddings/multimodal
# 火山方舟/LAS 控制台「API Key 管理」创建，通常为 sk- 开头（不要用 MILVUS_TOKEN）
EMBEDDING_API_KEY=sk-your_ark_api_key_here
EMBEDDING_MODEL=doubao-embedding-vision-250615
EMBEDDING_DIMENSIONS=2048
EMBEDDING_TIMEOUT_SECONDS=60

# Volcano Engine ASR v3 bigmodel（推荐 App-Key 鉴权，见 asr-integration-example.md）
ASR_APP_ID=your_volcengine_app_id
ASR_ACCESS_TOKEN=your_volcengine_access_token
# 兼容旧版单 Key 鉴权（二选一）
ASR_API_KEY=
ASR_RESOURCE_ID=volc.bigasr.auc
ASR_SUBMIT_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/submit
ASR_QUERY_URL=https://openspeech.bytedance.com/api/v3/auc/bigmodel/query
ASR_MODEL_NAME=bigmodel
ASR_AUDIO_FORMAT=mp3
ASR_ENABLE_ITN=true
ASR_ENABLE_PUNC=true
ASR_SHOW_UTTERANCES=true
ASR_TIMEOUT_SECONDS=60
ASR_POLL_INTERVAL_SECONDS=1.0
ASR_POLL_MAX_ATTEMPTS=120

# 3-second segmentation
SEGMENT_DURATION_MS=3000
SEGMENT_MIN_CHARS=6
SEGMENT_MAX_BORROW_WORDS=8
SEGMENT_MAX_CHARS=80
SEGMENT_SENTENCE_ENDINGS=。！？；.!?;

# Material matching
MATCH_FALLBACK_MATERIAL_ID=0
MILVUS_SEARCH_BATCH_SIZE=10
